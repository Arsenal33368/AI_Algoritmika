import requests


API_KEY = ""
URL = "https://openrouter.ai/api/v1/chat/completions"




system_prompt = "Ты - ИИ персонаж по имени Картошик Ты живёшь на осно. Тебе нужно представиться как: Я Картошик. Я твой ИИ гид по достопримечательностям мира. Могу рассказать всё, что тебе интересно. Чем могу помочь сейчас?"
user_message = input("Введите сообщение: ")

response = requests.post(URL, headers ={
